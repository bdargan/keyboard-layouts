;;(defalias
;;;; hold e or i for hyper key
;;hyper (multi lctl lalt lmet lshift)
;;e (t! charmod e (multi lctl lalt lmet lshift))
;;i (t! charmod i (multi rctl ralt rmet rshift))
;;a (t! charmod a lctl)
;;s (t! charmod s lalt)
;;d (t! charmod d lmet)
;;f (t! charmod f lsft)
;;j (t! charmod j rsft)
;;k (t! charmod k rmet)
;;l (t! charmod l ralt)
;;; (t! charmod ; rctl)
;;)

    
(defalias
  ;; Layout Profile Changers (Linked to numbers 1, 2, 3 inside the profile-control layer)
  to-col (layer-switch colemak-dh)
  to-str (layer-switch magic-sturdy)
  to-qwe (layer-switch qwerty)

  ;; Tapping outputs ` (backtick). Holding opens the Profile Control Layer.
  grv-ldr (tap-hold-release $tap-time $hold-time grv (layer-while-held profile-control))

  ;; Standard Layer Toggles
  ;; todo spc for syms no good for vim, conflict with my ldr 
  spc-sym (tap-hold-press $tap-time $hold-time spc (layer-while-held sym-r3))

  caps-esc-ctl (tap-hold-press $tap-time $hold-time esc lctl)
  rpt-sym (tap-hold $tap-time $hold-time rpt (layer-while-held sym-r3)) 
  
  ;; num-sym activate with ralt tap
  num-sym-r1 (tap-hold-release $tap-timeout $hold-time (one-shot-release-pcancel $one-shot-timeout (layer-while-held num-sym-r1)) ralt)

  ;; sym-num activate with lalt tap
  sym-num-r1 (tap-hold-release $tap-timeout $hold-time (one-shot-release-pcancel $one-shot-timeout (layer-while-held sym-num-r1)) lalt) 

  ;; 2. Left Thumb Magic Key on LMet (Fires magic on tap, acts as LMet on hold)
  ;; Add your specific Afterburner fallback 'rpt' macro logic inside your macro rules
  mgc-met (tap-hold $tap-time $hold-time @mgc lmet)

  ;; 3. Right Thumb Repeat Key on RMet (Fires repeat on tap, acts as RMet on hold)
  rpt-met (tap-hold $tap-time $hold-time rpt rmet)

  ;; =========================================================================
  ;; 1. Colemak-DH Home-Row Mods  - removed
  ;; Home-row SGAC: Shift, Gui/Cmd, Alt, Control
  ;; Home-row letters: A S R T | N E I O
  ;; =========================================================================

 ;; a_col (t! charmod a lsft )
 ;; r_col (t! charmod r lmet)
 ;; s_col (t! charmod s lalt ) ;; Left Cmd
 ;; t_col (t! charmod t lctl )
 ;; n_col (t! charmod n rctl )
 ;; e_col (t! charmod e ralt ) 
 ;; i_col (t! charmod i rmet );; Right Cmd
 ;; o_col (t! charmod o rsft )

  ;; 2. QWERTY Home-Row Mods
  a_qwe (t! charmod a lsft )
  s_qwe (t! charmod s lmet )
  d_qwe (t! charmod d lalt ) ;; Left Cmd
  f_qwe (t! charmod f lctl )
  j_qwe (t! charmod j rctl )
  k_qwe (t! charmod k ralt )
  l_qwe (t! charmod l rmet ) ;; Right Cmd
  sem_q (t! charmod ; rsft )

  ;; 3. Sturdy Home-Row Mods (Home row: S T R D  |  N E A I) 
  s_stu (t! charmod s lsft)
  t_stu (t! charmod t lmet)
  r_stu (t! charmod r lalt) ;; Left Cmd
  d_stu (t! charmod d lctl)
  n_stu (t! charmod n rctl)
  e_stu (t! charmod e ralt) ;; Right Cmd
  a_stu (t! charmod a rmet)
  i_stu (t! charmod i rsft)

)

;; ==========================================
;; BASE LAYER 1: default layer Pure QWERTY (Pass-Through Profile)
;; ==========================================
(deflayer qwerty
  esc      f1   f2   f3   f4   f5   f6   f7   f8   f9   f10  f11  f12
  @grv-ldr 1    2    3    4    5    6    7    8    9    0    -    =    bspc
  tab      q    w    e    r    t    y    u    i    o    p    [    ]    \
  @caps-esc-ctl a @s_qwe @d_qwe @f_qwe g    h    @j_qwe @k_qwe @l_qwe ; '    ret
  lsft     z    x    c    v    b    n    m    ,    .    /    rsft
  fn       lctl lalt lmet          @spc-sym        rmet ralt rctl
)

;; ==========================================
;; BASE LAYER 2: Colemak-DH (Default Alpha Profile)
;; ==========================================
(deflayer colemak-dh
  esc      f1   f2   f3   f4   f5   f6   f7   f8   f9   f10  f11  f12
  @grv-ldr 1    2    3    4    5    6    7    8    9    0    -    =    bspc
  tab      q    w    f    p    b    j    l    u    y    ;    [    ]    \
  @caps-esc-ctl     a     r    s t  g    m    n    e    i o '    ret
  lsft       x    c    d    v    z    k    h    ,    .    /    rsft
  fn lctl  @sym-num-r1 lmet                @spc-sym         @rpt-sym @num-sym-r1 rctl 
)

;; ==========================================
;; Original magic-sturdy from icelaks - 
;; ==========================================
;;V M L C P "        | B ^ U O , \
;;S T R D Y Q        $ F N E A I -
;;X K J G W            Z H ' ? .
;;        ⎵ ⇥     / @ ⇧
;;^ is the magic key, and @ is the repeat key.

;; ==========================================
;;2. Stagger-Neutral Alpha Translation
;; ==========================================
;;The alphanumeric blocks have been shifted horizontally by one unit on the top and bottom rows. 
;;This shift counteracts the physical slant of standard laptop keys, keeping the columns straight relative to your natural typing angles:
;;V  M  L  C  P        B  U  O  ,  .
;;S  T  R  D  Y        F  N  E  A  I  '
;;X  K  J  G  W        Z  H  /  ?  \
;; ==========================================
;; BASE LAYER 3: Magic Sturdy (Learning Profile)
;; ==========================================
(deflayer magic-sturdy
  esc          f1   f2             f3        f4   f5   f6   f7   f8   f9   f10  f11  f12
  @grv-ldr      1    2              3         4    5    6    7    8    9    0     -    @eq-main    bspc
  tab           v    m              l         c    p    b    u    o    ,    .     [    ]    \
  @caps-esc-ctl s    @t_stu    @r_stu    @d_stu    y    f    n    e    a    i     '  ret
  lsft          x         k         j         g    w    z    h    /    S-/  q  rsft
  fn       lctl lalt @mgc-met          @spc-sym @rpt-met ralt rctl
)

;; ==========================================
;; CONTROL LAYER: The Layout Dashboard (Hold Grave to access)
;; ==========================================
(deflayer profile-control
  _         _       _       _   _    _    _    _    _    _    _    _    _
  _   @to-qwe @to-col @to-str   _    _    _    _    _    _    _    _    _    _
  _    _       _       _        _    _    _    _    _    _    _    _    _    _
  lrld    _       lrld _        _    _    _    _    _    _    _    _    _
  _       _       _       _       _    _    _    _    _    _    _    _ 
  _       _       _       _            _              _    _  _
)

