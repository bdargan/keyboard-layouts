;; a (t! charmod a lmet)
;; s (t! charmod s lsft)
;; d (t! charmod d lctl)
;; f (t! charmod f lalt)
;; j (t! charmod j lalt)
;; k (t! charmod k rctl)
;; l (t! charmod l rsft)
;; ; (t! charmod ; rmet)
;; v (t! charmod v ralt)
;; m (t! charmod m ralt)
