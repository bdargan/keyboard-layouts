(defalias
  ;; --- EQUAL KEY LOGIC (=, ==, ===) ---
  eq-long (tap-hold 0 300 (macro-release-cancel 50 = 50 =) (macro-release-cancel 50 = 50 = 50 =))
  eq-main (tap-hold 0 150 = @eq-long)

  ;; --- HYPHEN KEY LOGIC (-, --, ---) ---
  hyp-long (tap-hold 0 300 (macro - -) (macro - - -))
  hyp-main (tap-hold 0 200 - @hyp-long)

  ;; --- PERIOD KEY LOGIC (., .., ...) ---
  dot-long (tap-hold 0 300 (macro . .) (macro . . .))
  dot-main (tap-hold 0 200 . @dot-long)
)

;; ==========================================
;; TODO: macros
;; ==========================================
(defseq
    dotcom (. S-3)
    dotorg (. S-4)

    ;;     The shifted letters in parentheses means a single press of lsft
    ;;     must remain held while both h and then s are pressed.
    ;;     This is not the same as S-h S-s, which means that the lsft key
    ;;     must be released and repressed between the h and s presses.
    https (S-(h s))
    vsplit (s d)
    hsplit (s x)
)
(defvirtualkeys
    dotcom (macro . c o m)
    dotorg (macro . o r g)
    https (macro h t t p s S-; / /)
    vsplit (macro S-; v s p l i t ret)
    hsplit (macro S-; h s p l i t ret)
)
